#!/bin/bash
# OfficialOnePesewa ZIVPN Dashboard v4.0

CONFIG="/etc/zivpn/config.json"
DB="/etc/zivpn/users.db"

# --- Colors ---
C="\e[1;36m"
G="\e[1;32m"
R="\e[1;31m"
Y="\e[1;33m"
M="\e[1;35m"
NC="\e[0m"
BOLD="\e[1m"

if ! command -v jq &>/dev/null; then
    echo -e "${Y}Installing jq...${NC}"
    apt-get install -y jq -qq &>/dev/null
fi

GEO=$(curl -4 -s --max-time 10 "https://ipapi.co/json/" 2>/dev/null)
IP=$(echo "$GEO" | grep -oP '"ip":\s*"\K[^"]+')
CITY=$(echo "$GEO" | grep -oP '"city":\s*"\K[^"]+')
COUNTRY=$(echo "$GEO" | grep -oP '"country_name":\s*"\K[^"]+')
ISP=$(echo "$GEO" | grep -oP '"org":\s*"\K[^"]+')
OS_INFO=$(grep "PRETTY_NAME" /etc/os-release | cut -d '"' -f 2)

[ -z "$IP" ] && IP="N/A"
[ -z "$CITY" ] && CITY="Unknown"
[ -z "$COUNTRY" ] && COUNTRY="Unknown"
[ -z "$ISP" ] && ISP="Unknown"

banner() {
    clear
    DATE_TIME=$(date +"%A, %d %B %Y - %H:%M:%S")
    echo -e "${C}${BOLD}════════════════════════════════════════════════════════════${NC}"
    echo -e "${G}${BOLD}   ██████╗ ██████╗ ██╗   ██╗██████╗ ██████╗            ${NC}"
    echo -e "${G}${BOLD}  ██╔═══██╗██╔══██╗██║   ██║██╔══██╗██╔══██╗           ${NC}"
    echo -e "${G}${BOLD}  ██║   ██║██████╔╝██║   ██║██║  ██║██████╔╝           ${NC}"
    echo -e "${G}${BOLD}  ██║   ██║██╔═══╝ ██║   ██║██║  ██║██╔═══╝            ${NC}"
    echo -e "${G}${BOLD}  ╚██████╔╝██║     ╚██████╔╝██████╔╝██║                ${NC}"
    echo -e "${G}${BOLD}   ╚═════╝ ╚═╝      ╚═════╝ ╚═════╝ ╚═╝   ${Y}OP UDP PANEL${NC}"
    echo -e "${C}${BOLD}════════════════════════════════════════════════════════════${NC}"
    echo -e "${M} 👑 Admin    : @OfficialOnePesewa"
    echo -e "${M} 💻 OS       : ${OS_INFO}"
    echo -e "${M} 🌍 Server   : ${IP} (${CITY}, ${COUNTRY})"
    echo -e "${M} 🏢 ISP      : ${ISP}"
    echo -e "${M} ⏰ Time     : ${DATE_TIME}"
    echo -e "${C}${BOLD}════════════════════════════════════════════════════════════${NC}"
}

goodbye() {
    clear
    echo -e "${C}${BOLD}════════════════════════════════════════════════════════════${NC}"
    echo -e "${G}${BOLD}   ██████╗ ██████╗ ██╗   ██╗██████╗ ██████╗            ${NC}"
    echo -e "${G}${BOLD}  ██╔═══██╗██╔══██╗██║   ██║██╔══██╗██╔══██╗           ${NC}"
    echo -e "${G}${BOLD}  ██║   ██║██████╔╝██║   ██║██║  ██║██████╔╝           ${NC}"
    echo -e "${G}${BOLD}  ██║   ██║██╔═══╝ ██║   ██║██║  ██║██╔═══╝            ${NC}"
    echo -e "${G}${BOLD}  ╚██████╔╝██║     ╚██████╔╝██████╔╝██║                ${NC}"
    echo -e "${G}${BOLD}   ╚═════╝ ╚═╝      ╚═════╝ ╚═════╝ ╚═╝   ${Y}OP UDP PANEL${NC}"
    echo -e "${C}${BOLD}════════════════════════════════════════════════════════════${NC}"
    echo ""
    echo -e "${G}${BOLD}        Thanks For Using OP Panel! 🤗${NC}"
    echo -e "${Y}        See you again soon! 👋${NC}"
    echo ""
    echo -e "${M}        Admin   : @OfficialOnePesewa${NC}"
    echo -e "${M}        Channel : https://t.me/OfficialOnePesewa${NC}"
    echo ""
    echo -e "${C}${BOLD}════════════════════════════════════════════════════════════${NC}"
    echo ""
}

add_user() {
    echo -e "\n${Y}--- CREATE NEW USER ---${NC}"
    read -p "User Password: " pass
    read -p "Validity (Days): " days
    read -p "Quota (GB/MB): " quota
    read -p "Device ID (Optional): " devid

    exp=$(date -d "+$days days" +%Y-%m-%d)

    if [ -f "$CONFIG" ]; then
        jq --arg p "$pass" '.auth.config += [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
    fi

    echo "$pass|$exp|$quota|${devid:-None}" >> "$DB"
    systemctl restart zivpn 2>/dev/null || echo -e "${Y}Note: zivpn.service not running.${NC}"

    echo -e "\n${C}═════════════════════════════════════${NC}"
    echo -e "${G}${BOLD}   🎉 USER SUCCESSFULLY ADDED 🎉${NC}"
    echo -e "${C}═════════════════════════════════════${NC}"
    echo -e "${Y} 👤 Password   : ${G}$pass${NC}"
    echo -e "${Y} ⏳ Expiry     : ${G}$exp ($days Days)${NC}"
    echo -e "${Y} 📊 Quota      : ${G}$quota${NC}"
    echo -e "${Y} 📱 Device ID  : ${G}${devid:-None}${NC}"
    echo -e "${C}──────────────────────────────────${NC}"
    echo -e "${M} 🌍 Server IP  : ${G}$IP${NC}"
    echo -e "${M} 📍 Location   : ${G}$CITY, $COUNTRY${NC}"
    echo -e "${M} 🏢 ISP        : ${G}$ISP${NC}"
    echo -e "${C}═════════════════════════════════════${NC}"
}

trial_user() {
    read -p "Minutes (1-60): " mins
    pass="trial_$(openssl rand -hex 2)"
    if [ -f "$CONFIG" ]; then
        jq --arg p "$pass" '.auth.config += [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
        systemctl restart zivpn 2>/dev/null
    fi
    echo -e "${G}Trial Created: ${Y}$pass${G} (Expires in $mins mins)${NC}"
    (
        sleep $((mins * 60))
        if [ -f "$CONFIG" ]; then
            jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
            systemctl restart zivpn 2>/dev/null
        fi
    ) &
}

while true; do
    banner
    echo -e " ${G}1)${NC} Start ZIVPN          ${G}11)${NC} Bandwidth + Expiry"
    echo -e " ${G}2)${NC} Stop ZIVPN           ${G}12)${NC} Reset Bandwidth"
    echo -e " ${G}3)${NC} Restart ZIVPN        ${G}13)${NC} Speed Test"
    echo -e " ${G}4)${NC} Status               ${G}14)${NC} Live Logs"
    echo -e " ${G}5)${NC} List Users + Expiry  ${G}15)${NC} Backup All Data"
    echo -e " ${G}6)${NC} Add User             ${G}16)${NC} Restore Backup"
    echo -e " ${G}7)${NC} Remove User          ${G}17)${NC} Change Port Range"
    echo -e " ${G}8)${NC} Renew / Extend User  ${Y}18)${NC} Auto-Update Panel"
    echo -e " ${G}9)${NC} Cleanup Expired      ${G}19)${NC} Set Connection Limit"
    echo -e " ${G}10)${NC} Connection Stats    ${G}20)${NC} Trial User (1-60m)"
    echo -e "${C}────────────────────────────────────${NC}"
    echo -e " ${R}99) UNINSTALL${NC}           ${G}0) Exit${NC}"
    echo -e "${C}────────────────────────────────────${NC}"
    read -p " Choose [0-99]: " opt

    case $opt in
        1) systemctl start zivpn 2>/dev/null && echo -e "${G}ZIVPN Started.${NC}" || echo -e "${R}zivpn.service not found.${NC}" ;;
        2) systemctl stop zivpn 2>/dev/null && echo -e "${R}ZIVPN Stopped.${NC}" || echo -e "${R}zivpn.service not found.${NC}" ;;
        3) systemctl restart zivpn 2>/dev/null && echo -e "${G}ZIVPN Restarted.${NC}" || echo -e "${R}zivpn.service not found.${NC}" ;;
        4) systemctl status zivpn 2>/dev/null || echo -e "${R}zivpn.service not found.${NC}" ;;
        5)
           if [ -f "$DB" ]; then
               echo -e "\n${C}Pass | Expiry | Quota | DeviceID${NC}"
               echo "─────────────────────────────────"
               column -t -s "|" "$DB"
           else
               echo -e "${R}No database found.${NC}"
           fi
           ;;
        6) add_user ;;
        7)
           read -p "Password to remove: " pass
           [ -f "$DB" ] && sed -i "/^$pass|/d" "$DB"
           systemctl restart zivpn 2>/dev/null
           echo -e "${G}User removed.${NC}"
           ;;
        14) journalctl -u zivpn -f 2>/dev/null || echo -e "${R}zivpn.service not found.${NC}" ;;
        18)
           echo -e "\n${Y}Updating OPUDP panel...${NC}"
           wget -qO /usr/local/bin/opudp https://raw.githubusercontent.com/OfficialOnePesewa/opudp-panel/main/opudp
           chmod +x /usr/local/bin/opudp
           echo -e "${G}Updated! Restarting...${NC}"
           sleep 2
           exec opudp
           ;;
        20) trial_user ;;
        99)
           systemctl stop zivpn 2>/dev/null
           rm -rf /etc/zivpn /usr/local/bin/zivpn /usr/local/bin/opudp
           echo -e "${R}Uninstalled.${NC}"
           exit
           ;;
        0) goodbye; exit ;;
        *) echo -e "${R}Invalid option.${NC}" ;;
    esac
    echo ""
    read -p "Press Enter to continue..."
done
