#!/bin/bash
# OPUDP Panel Management Script
# Compatible with Debian 10+ / Ubuntu 20.04+
# Usage: opudp [command]

set -euo pipefail

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# --- Paths ---
ZIVPN_BIN="/usr/local/bin/zivpn"
CONFIG_FILE="/etc/zivpn/config.json"
USERS_DB="/etc/zivpn/users.db"
SERVICE_NAME="zivpn"
PANEL_VERSION="2.0.0"

# --- Helper Functions ---
log()    { echo -e "${GREEN}[INFO]${NC} $1"; }
warn()   { echo -e "${YELLOW}[WARN]${NC} $1"; }
error()  { echo -e "${RED}[ERROR]${NC} $1"; exit 1; }
success(){ echo -e "${GREEN}[✓]${NC} $1"; }

# Check if running as root
check_root() {
    if [[ $EUID -ne 0 ]]; then
        error "This command must be run as root. Try: sudo opudp $*"
    fi
}

# Ensure ZIVPN is installed
check_installed() {
    if [[ ! -f "$ZIVPN_BIN" ]]; then
        error "ZIVPN is not installed. Please run the installer first."
    fi
}

# Get server public IP
get_ip() {
    curl -s --max-time 5 ifconfig.me || \
    curl -s --max-time 5 ipinfo.io/ip || \
    hostname -I | awk '{print $1}'
}

# --- User Management ---
add_user() {
    local username="$1"
    local password="$2"
    local limit="${3:-0}"  # 0 = unlimited

    if [[ -z "$username" || -z "$password" ]]; then
        error "Usage: opudp add <username> <password> [device_limit]"
    fi

    # Check if user already exists
    if grep -q "^$username:" "$USERS_DB" 2>/dev/null; then
        error "User '$username' already exists."
    fi

    echo "$username:$password:$limit" >> "$USERS_DB"
    chmod 600 "$USERS_DB"

    # Update ZIVPN config
    update_zivpn_auth

    success "User '$username' added successfully."
    if [[ "$limit" -gt 0 ]]; then
        echo "   Device limit: $limit"
    else
        echo "   Device limit: unlimited"
    fi
}

remove_user() {
    local username="$1"
    if [[ -z "$username" ]]; then
        error "Usage: opudp remove <username>"
    fi

    if ! grep -q "^$username:" "$USERS_DB" 2>/dev/null; then
        error "User '$username' not found."
    fi

    sed -i "/^$username:/d" "$USERS_DB"
    update_zivpn_auth

    success "User '$username' removed."
}

list_users() {
    if [[ ! -f "$USERS_DB" ]] || [[ ! -s "$USERS_DB" ]]; then
        warn "No users found."
        return
    fi

    echo -e "\n${BLUE}=== User List ===${NC}"
    printf "%-15s %-15s %s\n" "Username" "Password" "Device Limit"
    echo "----------------------------------------"
    while IFS=: read -r user pass limit; do
        [[ "$limit" == "0" ]] && limit="unlimited"
        printf "%-15s %-15s %s\n" "$user" "$pass" "$limit"
    done < "$USERS_DB"
    echo ""
}

update_zivpn_auth() {
    # Rebuild auth array from users.db
    local auth_config=""
    local first=true

    while IFS=: read -r user pass limit; do
        if [[ "$first" == true ]]; then
            auth_config+="{\"username\":\"$user\",\"password\":\"$pass\",\"device_limit\":$limit}"
            first=false
        else
            auth_config+=",{\"username\":\"$user\",\"password\":\"$pass\",\"device_limit\":$limit}"
        fi
    done < "$USERS_DB"

    # Use jq to update config.json safely
    if command -v jq &>/dev/null; then
        jq --argjson auth "[$auth_config]" '.auth.config = $auth' "$CONFIG_FILE" > "${CONFIG_FILE}.tmp"
        mv "${CONFIG_FILE}.tmp" "$CONFIG_FILE"
    else
        # Fallback manual sed (less safe)
        warn "jq not found, using sed fallback (may fail with special characters)."
        sed -i "s/\"config\": \[.*\]/\"config\": [$auth_config]/" "$CONFIG_FILE"
    fi

    # Reload service
    systemctl reload "$SERVICE_NAME" 2>/dev/null || systemctl restart "$SERVICE_NAME"
    log "ZIVPN config updated and service reloaded."
}

# --- Service Control ---
service_status() {
    systemctl status "$SERVICE_NAME" --no-pager
}

service_restart() {
    systemctl restart "$SERVICE_NAME"
    success "ZIVPN service restarted."
}

service_logs() {
    journalctl -u "$SERVICE_NAME" -f
}

# --- Configuration Display ---
show_config() {
    check_installed
    local ip=$(get_ip)
    local port=$(grep -oP '"listen":\s*":\K\d+' "$CONFIG_FILE" 2>/dev/null || echo "5667")
    local obfs=$(grep -oP '"obfs":\s*"\K[^"]+' "$CONFIG_FILE" 2>/dev/null || echo "zivpn")

    echo -e "\n${BLUE}=== OPUDP Panel Configuration ===${NC}"
    echo -e "Server IP     : ${GREEN}$ip${NC}"
    echo -e "UDP Port      : ${GREEN}$port${NC}"
    echo -e "Obfuscation   : ${GREEN}$obfs${NC}"
    echo -e "User DB       : $USERS_DB"
    echo -e "Service       : ${GREEN}$(systemctl is-active "$SERVICE_NAME")${NC}"
    echo -e "\nPort range 6000-19999 forwards to $port automatically."
    echo -e "Use 'opudp list' to see users.\n"
}

# --- Uninstall ---
uninstall() {
    warn "This will completely remove OPUDP Panel and ZIVPN."
    read -p "Are you sure? (y/N): " confirm
    if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
        echo "Uninstall cancelled."
        exit 0
    fi

    systemctl stop "$SERVICE_NAME" 2>/dev/null || true
    systemctl disable "$SERVICE_NAME" 2>/dev/null || true
    rm -f /etc/systemd/system/zivpn.service
    rm -f /usr/local/bin/zivpn
    rm -f /usr/local/bin/opudp
    rm -rf /etc/zivpn

    # Remove iptables rules
    iptables -D INPUT -p udp --dport 5667 -j ACCEPT 2>/dev/null || true
    iptables -D INPUT -p udp --dport 6000:19999 -j ACCEPT 2>/dev/null || true
    iptables -t nat -D PREROUTING -p udp --dport 6000:19999 -j DNAT --to-destination :5667 2>/dev/null || true
    netfilter-persistent save 2>/dev/null || true

    success "OPUDP Panel and ZIVPN have been removed."
}

# --- Help ---
show_help() {
    cat <<EOF
${BLUE}OPUDP Panel v${PANEL_VERSION}${NC} - Manage ZIVPN UDP Server

${GREEN}Usage:${NC} opudp [command] [arguments]

${GREEN}User Management:${NC}
  add <user> <pass> [limit]   Add a new user (limit 0=unlimited)
  remove <user>               Remove a user
  list                        List all users

${GREEN}Service Control:${NC}
  status                      Show service status
  restart                     Restart ZIVPN service
  logs                        View live service logs

${GREEN}Information:${NC}
  config                      Show server configuration
  ip                          Show server public IP

${GREEN}Maintenance:${NC}
  uninstall                   Completely remove OPUDP Panel
  help                        Show this help message

${YELLOW}Examples:${NC}
  opudp add alice mysecret123 2
  opudp remove alice
  opudp list
  opudp restart
EOF
}

# --- Main ---
main() {
    if [[ $# -eq 0 ]]; then
        show_help
        exit 0
    fi

    case "$1" in
        add)
            check_root
            check_installed
            add_user "$2" "$3" "$4"
            ;;
        remove|del|delete)
            check_root
            check_installed
            remove_user "$2"
            ;;
        list|ls)
            check_root
            check_installed
            list_users
            ;;
        status)
            check_root
            service_status
            ;;
        restart|reload)
            check_root
            service_restart
            ;;
        logs|log)
            check_root
            service_logs
            ;;
        config|info)
            check_root
            show_config
            ;;
        ip)
            get_ip
            ;;
        uninstall|remove-all)
            check_root
            uninstall
            ;;
        help|-h|--help)
            show_help
            ;;
        *)
            error "Unknown command: $1. Run 'opudp help' for usage."
            ;;
    esac
}

main "$@"
