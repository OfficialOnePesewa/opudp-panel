#!/bin/bash
# OPUDP Panel v2.0 - Complete Management Interface
# Usage: opudp

set -euo pipefail

# --- Colors & Config ---
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; NC='\033[0m'

ZIVPN_BIN="/usr/local/bin/zivpn"
CONFIG_FILE="/etc/zivpn/config.json"
USERS_DB="/etc/zivpn/users.db"
SERVICE_NAME="zivpn"
BACKUP_DIR="/root/opudp_backup"
PANEL_VERSION="2.0.0"

# Ensure root
[[ $EUID -eq 0 ]] || { echo -e "${RED}Run as root.${NC}"; exit 1; }

# Helper functions
log()    { echo -e "${GREEN}[✓]${NC} $1"; }
warn()   { echo -e "${YELLOW}[!]${NC} $1"; }
error()  { echo -e "${RED}[✗]${NC} $1"; }
info()   { echo -e "${CYAN}[i]${NC} $1"; }

get_ip() {
    curl -s --max-time 5 ifconfig.me || curl -s --max-time 5 ipinfo.io/ip || hostname -I | awk '{print $1}'
}

# Sync users.db to ZIVPN config.json
sync_auth() {
    local auth_array=""
    local first=true
    while IFS=: read -r user pass limit expiry; do
        [[ -z "$user" ]] && continue
        limit="${limit:-0}"
        expiry="${expiry:-0}"
        if [[ "$first" == true ]]; then
            auth_array+="{\"username\":\"$user\",\"password\":\"$pass\",\"device_limit\":$limit,\"expiry\":$expiry}"
            first=false
        else
            auth_array+=",{\"username\":\"$user\",\"password\":\"$pass\",\"device_limit\":$limit,\"expiry\":$expiry}"
        fi
    done < "$USERS_DB"
    jq --argjson auth "[$auth_array]" '.auth.config = $auth' "$CONFIG_FILE" > "${CONFIG_FILE}.tmp"
    mv "${CONFIG_FILE}.tmp" "$CONFIG_FILE"
    systemctl reload "$SERVICE_NAME" 2>/dev/null || systemctl restart "$SERVICE_NAME"
}

# ========== Menu Header ==========
menu_header() {
    clear
    echo -e "${CYAN}╔══════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║${NC}                  ${GREEN}OPUDP PANEL v${PANEL_VERSION}${NC}                         ${CYAN}║${NC}"
    echo -e "${CYAN}╠══════════════════════════════════════════════════════════════╣${NC}"
    echo -e "${CYAN}║${NC} IP: ${GREEN}$(get_ip)${NC} | OS: ${YELLOW}$(. /etc/os-release; echo $PRETTY_NAME)${NC}  ${CYAN}║${NC}"
    local status=$(systemctl is-active zivpn)
    if [[ "$status" == "active" ]]; then
        status_colored="${GREEN}active${NC}"
    else
        status_colored="${RED}inactive${NC}"
    fi
    echo -e "${CYAN}║${NC} ZIVPN: $status_colored${CYAN}                             ║${NC}"
    local user_count=$(grep -c ':' "$USERS_DB" 2>/dev/null || echo 0)
    local port=$(grep -oP '"listen":\s*":\K\d+' "$CONFIG_FILE" 2>/dev/null || echo "5667")
    echo -e "${CYAN}║${NC} Users: $user_count | Port: $port${CYAN}                                  ║${NC}"
    echo -e "${CYAN}╚══════════════════════════════════════════════════════════════╝${NC}"
    echo ""
}

# ========== Service Control ==========
start_zivpn()   { systemctl start zivpn && log "ZIVPN started."; }
stop_zivpn()    { systemctl stop zivpn && log "ZIVPN stopped."; }
restart_zivpn() { systemctl restart zivpn && log "ZIVPN restarted."; }
status_zivpn()  { systemctl status zivpn --no-pager; }

# ========== User Management ==========
list_users() {
    echo -e "\n${BLUE}Username        Password        Limit   Expiry${NC}"
    echo "----------------------------------------------"
    while IFS=: read -r u p l e; do
        [[ -z "$u" ]] && continue
        l="${l:-0}"; e="${e:-0}"
        if [[ "$e" == "0" ]]; then
            e_disp="Never"
        else
            e_disp=$(date -d "@$e" "+%Y-%m-%d" 2>/dev/null || echo "Invalid")
        fi
        printf "%-15s %-15s %-6s %s\n" "$u" "$p" "$l" "$e_disp"
    done < "$USERS_DB"
    echo ""
}

add_user() {
    read -p "Username (for panel reference): " user
    read -p "Password (used in ZIVPN app): " pass
    read -p "Device Limit (0=unlimited): " limit
    limit="${limit:-0}"
    read -p "Expiry days (0=never): " days
    expiry=0
    [[ "$days" -gt 0 ]] && expiry=$(date -d "+$days days" +%s)
    if grep -q "^$user:" "$USERS_DB"; then
        error "User already exists."
        return
    fi
    echo "$user:$pass:$limit:$expiry" >> "$USERS_DB"
    chmod 600 "$USERS_DB"
    sync_auth
    log "User $user added."
    echo ""
    echo -e "${GREEN}Connection Details for ZIVPN App:${NC}"
    echo -e "  UDP Server : ${YELLOW}$(get_ip)${NC}"
    echo -e "  UDP Password: ${YELLOW}$pass${NC}"
    echo ""
}

remove_user() {
    read -p "Username to remove: " user
    if ! grep -q "^$user:" "$USERS_DB"; then
        error "User not found."
        return
    fi
    sed -i "/^$user:/d" "$USERS_DB"
    sync_auth
    log "User $user removed."
}

renew_user() {
    read -p "Username: " user
    if ! grep -q "^$user:" "$USERS_DB"; then
        error "User not found."
        return
    fi
    read -p "Extend by days: " days
    curr_expiry=$(grep "^$user:" "$USERS_DB" | cut -d: -f4)
    if [[ "$curr_expiry" -eq 0 ]]; then
        new_expiry=$(date -d "+$days days" +%s)
    else
        new_expiry=$((curr_expiry + days*86400))
    fi
    sed -i "s/^$user:\([^:]*\):\([^:]*\):[^:]*$/$user:\1:\2:$new_expiry/" "$USERS_DB"
    sync_auth
    log "User $user renewed until $(date -d "@$new_expiry")."
}

cleanup_expired() {
    now=$(date +%s)
    count=0
    while IFS=: read -r u p l e; do
        if [[ "$e" != "0" && "$e" -lt "$now" ]]; then
            sed -i "/^$u:/d" "$USERS_DB"
            ((count++))
        fi
    done < "$USERS_DB"
    sync_auth
    log "Removed $count expired users."
}

# ========== Stats & Monitoring ==========
connection_stats() {
    info "Recent connections (last hour):"
    journalctl -u zivpn --since "1 hour ago" | grep -i "connected" | tail -20 || echo "No recent connections logged."
}

bandwidth_expiry() {
    info "Bandwidth usage (interface eth0):"
    vnstat -i eth0 -m 2>/dev/null || warn "vnstat not configured for eth0."
}

reset_bandwidth() {
    warn "Per-user bandwidth reset is not implemented in ZIVPN."
}

speed_test() {
    if ! command -v speedtest-cli &>/dev/null; then
        apt-get install -y speedtest-cli 2>/dev/null
    fi
    speedtest-cli --simple
}

live_logs() {
    journalctl -u zivpn -f
}

# ========== Backup & Restore ==========
backup_data() {
    mkdir -p "$BACKUP_DIR"
    local file="$BACKUP_DIR/opudp_backup_$(date +%Y%m%d_%H%M%S).tar.gz"
    tar -czf "$file" /etc/zivpn /usr/local/bin/zivpn /etc/systemd/system/zivpn.service 2>/dev/null
    log "Backup saved to $file"
}

restore_backup() {
    ls "$BACKUP_DIR"/*.tar.gz 2>/dev/null || { error "No backups found."; return; }
    read -p "Backup file to restore: " file
    if [[ ! -f "$file" ]]; then
        error "File not found."
        return
    fi
    tar -xzf "$file" -C /
    systemctl daemon-reload
    systemctl restart zivpn
    log "Restored from $file"
}

# ========== Configuration ==========
change_port_range() {
    read -p "New main port (default 5667): " new_port
    new_port="${new_port:-5667}"
    read -p "Start of forward range (default 6000): " start_port
    start_port="${start_port:-6000}"
    read -p "End of forward range (default 19999): " end_port
    end_port="${end_port:-19999}"
    # Update config
    jq --arg port ":$new_port" '.listen = $port' "$CONFIG_FILE" > tmp && mv tmp "$CONFIG_FILE"
    # Update firewall
    iptables -F INPUT 2>/dev/null; iptables -t nat -F PREROUTING 2>/dev/null
    iptables -I INPUT -p udp --dport "$new_port" -j ACCEPT
    iptables -I INPUT -p udp --dport "$start_port:$end_port" -j ACCEPT
    iptables -t nat -A PREROUTING -p udp --dport "$start_port:$end_port" -j DNAT --to-destination ":$new_port"
    netfilter-persistent save
    systemctl restart zivpn
    log "Port range updated."
}

auto_update() {
    warn "This will download the latest panel script from GitHub."
    read -p "Continue? (y/N): " yn
    [[ "$yn" == "y" ]] || return
    wget -O /usr/local/bin/opudp https://raw.githubusercontent.com/OfficialOnePesewa/opudp-panel/main/opudp
    chmod +x /usr/local/bin/opudp
    log "Panel updated. Restart the menu."
    exit 0
}

set_conn_limit() {
    read -p "Global connection limit (0=unlimited): " limit
    sed -i "s/LimitNOFILE=.*/LimitNOFILE=$((limit*2))/" /etc/systemd/system/zivpn.service
    systemctl daemon-reload
    systemctl restart zivpn
    log "Limit set (via file descriptor limit)."
}

trial_user() {
    read -p "Trial duration in minutes (1-60): " mins
    if [[ "$mins" -lt 1 || "$mins" -gt 60 ]]; then
        error "Invalid duration."
        return
    fi
    user="trial$(date +%s | tail -c5)"
    pass=$(openssl rand -base64 6)
    expiry=$(date -d "+$mins minutes" +%s)
    echo "$user:$pass:1:$expiry" >> "$USERS_DB"
    sync_auth
    log "Trial user created:"
    echo -e "  UDP Server : $(get_ip)"
    echo -e "  UDP Password: $pass"
    echo -e "  Expires in $mins minutes."
}

uninstall_all() {
    warn "This will remove OPUDP Panel and ZIVPN completely."
    read -p "Are you sure? Type 'yes' to confirm: " confirm
    [[ "$confirm" == "yes" ]] || return
    systemctl stop zivpn; systemctl disable zivpn
    rm -f /etc/systemd/system/zivpn.service
    rm -f /usr/local/bin/zivpn /usr/local/bin/opudp
    rm -rf /etc/zivpn
    iptables -F; iptables -t nat -F; netfilter-persistent save 2>/dev/null
    log "Uninstalled."
    exit 0
}

# ========== Main Menu ==========
while true; do
    menu_header
    echo " 1) Start ZIVPN              11) Bandwidth + Expiry"
    echo " 2) Stop ZIVPN               12) Reset User Bandwidth"
    echo " 3) Restart ZIVPN            13) Speed Test"
    echo " 4) Status                   14) Live Logs"
    echo " 5) List Users               15) Backup Data"
    echo " 6) Add User                 16) Restore Backup"
    echo " 7) Remove User              17) Change Port Range"
    echo " 8) Renew / Extend User      18) Auto-Update Panel"
    echo " 9) Cleanup Expired          19) Set Connection Limit"
    echo "10) Connection Stats         20) Trial User (1-60m)"
    echo ""
    echo "99) UNINSTALL                 0) Exit"
    echo ""
    read -p "Choose [0-99]: " choice

    case $choice in
        1) start_zivpn ;;
        2) stop_zivpn ;;
        3) restart_zivpn ;;
        4) status_zivpn ;;
        5) list_users ;;
        6) add_user ;;
        7) remove_user ;;
        8) renew_user ;;
        9) cleanup_expired ;;
        10) connection_stats ;;
        11) bandwidth_expiry ;;
        12) reset_bandwidth ;;
        13) speed_test ;;
        14) live_logs ;;
        15) backup_data ;;
        16) restore_backup ;;
        17) change_port_range ;;
        18) auto_update ;;
        19) set_conn_limit ;;
        20) trial_user ;;
        99) uninstall_all ;;
        0) echo "Goodbye!"; exit 0 ;;
        *) error "Invalid option." ;;
    esac
    read -p "Press Enter to continue..."
done
